@@
+    /*
+     * Temporary CoreDevice-era fallback for modern Xcode installs.
+     *
+     * Xcode 15+ keeps developer disk images under /Library/Developer/DeveloperDiskImages
+     * and device management is expected to flow through CoreDevice/devicectl instead of
+     * the legacy DeviceSupport/<version>/DeveloperDiskImage.dmg layout. Until RoboVM grows
+     * native support, prefer devicectl when it is available and a modern DDI layout is
+     * detected. Fall back to the old mounting path for older Xcode setups.
+     */
+    private boolean tryLaunchWithDeviceCtl() {
+        if (!isDeviceCtlAvailable() || !hasModernDeveloperDiskImages()) {
+            return false;
+        }
+
+        String appPath = config.getInstallDir().getAbsolutePath();
+        String bundleIdentifier = readBundleIdentifier(new File(appPath, "Info.plist"));
+
+        exec("xcrun", "devicectl", "device", "install", "app",
+                "--device", device.getUdid(), appPath);
+        exec("xcrun", "devicectl", "device", "process", "launch",
+                "--device", device.getUdid(), "--terminate-existing", bundleIdentifier);
+        return true;
+    }
+
+    private boolean isDeviceCtlAvailable() {
+        return which("xcrun") && execQuiet("xcrun", "devicectl", "help") == 0;
+    }
+
+    private boolean hasModernDeveloperDiskImages() {
+        File modernDdiDir = new File("/Library/Developer/DeveloperDiskImages");
+        return modernDdiDir.isDirectory();
+    }
