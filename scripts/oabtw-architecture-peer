#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./oabtw-lib.sh
source "$SCRIPT_DIR/oabtw-lib.sh"

scope="${*:-libGDX rewrite architecture synthesis}"

ensure_layout
require_oabtw

run_dir="$(make_run_dir "architecture" "$scope")"
brief_file="$run_dir/brief.md"
write_run_brief "$brief_file" "architecture" "$scope"

runtime_doc="$run_dir/results/runtime-model.md"
conventions_doc="$run_dir/results/conventions.md"
assets_doc="$run_dir/results/assets.md"
migration_doc="$run_dir/results/migration-map.md"

analysis_inputs=(
    "$ORIGINAL_DOCS_DIR/overview.md"
    "$ORIGINAL_DOCS_DIR/gameplay-rules.md"
    "$ORIGINAL_DOCS_DIR/runtime-shell.md"
    "$ORIGINAL_DOCS_DIR/services-data.md"
    "$ORIGINAL_DOCS_DIR/gameplay-rules-review.md"
    "$ORIGINAL_DOCS_DIR/runtime-shell-review.md"
    "$ORIGINAL_DOCS_DIR/services-data-review.md"
    "$ORIGINAL_DOCS_DIR/cross-boundary-review.md"
)

read_list=()
for file in "${analysis_inputs[@]}"; do
    if [[ -f "$file" ]]; then
        read_list+=("- $file")
    fi
done

read_block=""
if [[ ${#read_list[@]} -gt 0 ]]; then
    read_block="$(printf '%s\n' "${read_list[@]}")"
fi

common_context="$(cat <<EOF
Read:
- $brief_file
$read_block

Use official libGDX guidance as the architecture baseline:
- Game plus Screen flow
- thin Android and iOS launchers
- AssetManager as central runtime loader
- platform-specific interfaces implemented outside core
- desktop backend retained for development and testing
EOF
)"

run_codox_job "docs" "$runtime_doc" "$(cat <<EOF
$common_context

Write docs/architecture/runtime-model.md.

Define:
- module boundaries
- runtime loop ownership
- screen flow
- subsystem split
- core/platform dependency rules
- deterministic gameplay boundaries
EOF
)"

run_codox_job "docs" "$conventions_doc" "$(cat <<EOF
$common_context

Write docs/architecture/conventions.md.

Define:
- package conventions
- naming rules
- what belongs in core vs platform modules
- state, command, and event conventions
- forbidden patterns carried over from the legacy app
EOF
)"

run_codox_job "docs" "$assets_doc" "$(cat <<EOF
$common_context

Write docs/architecture/assets.md.

Define:
- raw vs built asset layout
- AssetManager loading policy
- atlases, fonts, audio, and manifest conventions
- user-imported beatmap, skin, and replay handling
- cache invalidation and versioning rules
EOF
)"

run_codox_job "docs" "$migration_doc" "$(cat <<EOF
$common_context

Write docs/architecture/migration-map.md.

Define:
- behavior to preserve
- structure to discard
- first systems to implement in the rewrite spike
- parity tests required before feature expansion
- legacy hotspots that need deeper tracing
EOF
)"

copy_if_exists "$runtime_doc" "$ARCH_DOCS_DIR/runtime-model.md"
copy_if_exists "$conventions_doc" "$ARCH_DOCS_DIR/conventions.md"
copy_if_exists "$assets_doc" "$ARCH_DOCS_DIR/assets.md"
copy_if_exists "$migration_doc" "$ARCH_DOCS_DIR/migration-map.md"

printf 'Architecture synthesis complete.\n'
printf 'Run dir: %s\n' "$run_dir"
printf 'Docs   : %s\n' "$ARCH_DOCS_DIR"
