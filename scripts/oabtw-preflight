#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./oabtw-lib.sh
source "$SCRIPT_DIR/oabtw-lib.sh"

ensure_layout

status=0

report() {
    local level="$1"
    local label="$2"
    local detail="$3"
    printf '%-5s %-20s %s\n' "$level" "$label" "$detail"
}

fail() {
    status=1
    report "FAIL" "$1" "$2"
}

pass() {
    report "PASS" "$1" "$2"
}

warn() {
    report "WARN" "$1" "$2"
}

command_path_or_empty() {
    if command -v "$1" >/dev/null 2>&1; then
        command -v "$1"
    fi
}

run_version_check() {
    local label="$1"
    local cmd="$2"
    local tmp_file

    tmp_file="$(mktemp)"
    if bash -lc "$cmd" >"$tmp_file" 2>&1; then
        pass "$label" "$(head -n 1 "$tmp_file")"
    else
        fail "$label" "$(head -n 3 "$tmp_file" | tr '\n' ' ' | sed 's/  */ /g')"
    fi
    rm -f "$tmp_file"
}

printf 'Repository: %s\n' "$REPO_ROOT"
printf 'Docs root : %s\n' "$DOCS_ROOT"
printf 'Scratch   : %s\n\n' "$SCRATCH_ROOT"

if [[ -x "$OABTW_CODEX" ]]; then
    pass "oabtw-codex" "$OABTW_CODEX"
else
    fail "oabtw-codex" "Missing $OABTW_CODEX"
fi

if [[ -x "$OABTW_PEER" ]]; then
    pass "oabtw-peer" "$OABTW_PEER"
else
    fail "oabtw-peer" "Missing $OABTW_PEER"
fi

run_version_check "java" "java -version"
run_version_check "gradle" "gradle -v"

if command -v xcodebuild >/dev/null 2>&1; then
    run_version_check "xcodebuild" "xcodebuild -version"
else
    fail "xcodebuild" "xcodebuild not found"
fi

if xcrun --find devicectl >/dev/null 2>&1; then
    pass "devicectl" "$(xcrun --find devicectl)"
else
    fail "devicectl" "xcrun could not find devicectl"
fi

xcdevice_output="$(xcrun xcdevice list 2>&1 || true)"
if printf '%s' "$xcdevice_output" | rg -q '"name" : "iPhone'; then
    pass "ios-device" "Connected iPhone visible to xcdevice"
else
    fail "ios-device" "$(printf '%s' "$xcdevice_output" | head -n 3 | tr '\n' ' ' | sed 's/  */ /g')"
fi

adb_path="$(command_path_or_empty adb)"
if [[ -z "$adb_path" && -x "$HOME/Library/Android/sdk/platform-tools/adb" ]]; then
    adb_path="$HOME/Library/Android/sdk/platform-tools/adb"
fi

if [[ -n "$adb_path" ]]; then
    adb_output="$("$adb_path" devices -l 2>&1 || true)"
    if printf '%s' "$adb_output" | rg -q 'device '; then
        pass "android-device" "$(printf '%s' "$adb_output" | sed -n '2p')"
    else
        fail "android-device" "$(printf '%s' "$adb_output" | tr '\n' ' ' | sed 's/  */ /g')"
    fi
else
    fail "adb" "adb not found on PATH or under \$HOME/Library/Android/sdk/platform-tools"
fi

if [[ -d "$ORIGINAL_DOCS_DIR" ]]; then
    pass "legacy-docs" "$ORIGINAL_DOCS_DIR"
else
    warn "legacy-docs" "Will be created on first peer run"
fi

if [[ -d "$ARCH_DOCS_DIR" ]]; then
    pass "architecture-docs" "$ARCH_DOCS_DIR"
else
    warn "architecture-docs" "Will be created on first architecture synthesis"
fi

exit "$status"
