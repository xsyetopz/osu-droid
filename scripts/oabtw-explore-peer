#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./oabtw-lib.sh
source "$SCRIPT_DIR/oabtw-lib.sh"

scope="${*:-active libGDX rewrite root and preserved legacy dossiers}"

ensure_layout
require_oabtw

run_dir="$(make_run_dir "explore" "$scope")"
brief_file="$run_dir/brief.md"
write_run_brief "$brief_file" "explore" "$scope"

lane1="$run_dir/results/lane1-gameplay-rules.md"
lane2="$run_dir/results/lane2-runtime-shell.md"
lane3="$run_dir/results/lane3-services-data.md"
summary="$run_dir/results/summary.md"

prompt_lane1="$(cat <<EOF
Read $brief_file first.

Explore scope: $scope

Ownership:
- core
- docs/original-codebase/gameplay-rules.md
- docs/original-codebase/gameplay-rules-review.md

Produce:
- Current Shape
- Rewrite-Relevant Behavior
- Architecture To Discard
- Hotspots
- Missing Tests
- Next Traces

Focus on gameplay systems, deterministic logic boundaries, and how the active `core` implementation lines up with preserved gameplay findings.
EOF
)"

prompt_lane2="$(cat <<EOF
Read $brief_file first.

Explore scope: $scope

Ownership:
- android
- ios
- lwjgl3
- docs/original-codebase/runtime-shell.md
- docs/original-codebase/runtime-shell-review.md

Produce:
- Current Shape
- Rewrite-Relevant Behavior
- Architecture To Discard
- Hotspots
- Missing Tests
- Next Traces

Focus on launcher boundaries, platform service wiring, and where the new runtime still needs to absorb lessons from the old shell.
EOF
)"

prompt_lane3="$(cat <<EOF
Read $brief_file first.

Explore scope: $scope

Ownership:
- tools
- assets
- docs/architecture
- docs/original-codebase/services-data.md
- docs/original-codebase/services-data-review.md

Produce:
- Current Shape
- Rewrite-Relevant Behavior
- Architecture To Discard
- Hotspots
- Missing Tests
- Next Traces

Focus on asset policy, tooling, docs, and pending service/data boundaries that still need concrete rewrite implementations.
EOF
)"

run_codox_job "explore" "$lane1" "$prompt_lane1" &
pid1=$!
run_codox_job "explore" "$lane2" "$prompt_lane2" &
pid2=$!
run_codox_job "explore" "$lane3" "$prompt_lane3" &
pid3=$!

wait "$pid1" "$pid2" "$pid3"

summary_prompt="$(cat <<EOF
Read:
- $brief_file
- $lane1
- $lane2
- $lane3

Produce a concise synthesis for the libGDX rewrite.

Required sections:
- System Shape
- Preserve For Rewrite
- Discard With AndEngine
- Cross-Boundary Risks
- Recommended Migration Order
- Files Or Symbols Worth Immediate Tracing
EOF
)"

run_codox_job "orchestrate" "$summary" "$summary_prompt"

copy_if_exists "$lane1" "$ORIGINAL_DOCS_DIR/gameplay-rules.md"
copy_if_exists "$lane2" "$ORIGINAL_DOCS_DIR/runtime-shell.md"
copy_if_exists "$lane3" "$ORIGINAL_DOCS_DIR/services-data.md"
copy_if_exists "$summary" "$ORIGINAL_DOCS_DIR/overview.md"

printf 'Explore peer run complete.\n'
printf 'Run dir: %s\n' "$run_dir"
printf 'Docs   : %s\n' "$ORIGINAL_DOCS_DIR"
